# MongoDB connection string (Replica set or MongoDB Atlas required for transactions)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/autobank?retryWrites=true&w=majority

# JWT secret key for signature verification
JWT_SECRET=your_jwt_secret_key_here

# Gmail SMTP OAuth2 Configuration (Optional, for notifications)
EMAIL_USER=your_email@gmail.com
CLIENT_ID=your_oauth2_client_id.apps.googleusercontent.com
CLIENT_SECRET=your_oauth2_client_secret
REFRESH_TOKEN=your_oauth2_refresh_token